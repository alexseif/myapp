<!DOCTYPE html>

<title>TaskLists</title>

{% block body %}
    <h1>TaskLists</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ task_list.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ task_list.name }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ task_list.status }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('tasklists_index') }}">back to list</a>

    <a href="{{ path('tasklists_edit', {'id': task_list.id}) }}">edit</a>

    {{ include('tasklists/_delete_form.html.twig') }}
{% endblock %}
