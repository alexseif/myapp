{% extends 'base.html.twig' %}
{% import "AppBundle:tasks:tasks_macros.html.twig" as tasks_view %}
{% block title %}Workarea{% endblock %}
{# TODO: http://bootsnipp.com/user/favorites #}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" type="text/css" href="{{ asset('/css/dashboard.css') }}"/>
    <link href="{{ asset('/css/inbox.css') }}" rel="stylesheet" type="text/css"/>
{% endblock %}
{% block pageActions %}
    <div class="floating-action dropup">
        <button class="btn btn-info dropdown-toggle" type="button" id="dashboardMenuButton"
                data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            <i class="fas fa-plus"></i>
        </button>
        <div class="dropdown-menu" aria-labelledby="dashboardMenuButton">
            <a class="dropdown-item mb-2 btn bg-primary" href="{{ path('tasks_new') }}" id="newTask">
                <i class="fas fa-check"></i></a>
            <a class="dropdown-item mb-2 btn bg-primary" href="{{ path('tasklists_new') }}">
                <i class="fas fa-clipboard-list"></i></a>
            <a class="dropdown-item mb-2 btn bg-primary" href="{{ path('days_new') }}" id="newDay">
                <i class="fas fa-calendar-day"></i></a>
            <a class="dropdown-item mb-2 btn bg-primary" href="{{ path('notes_new') }}">
                <i class="far fa-sticky-note"></i></a>
        </div>
    </div>
{% endblock %}
{% block content %}
    <div id="inbox">
        <div class="row">
            <div class="col-xs-12 col-sm-6 col-md-2 col-lg-2">
                <div class="col-wrapper">
                    <ul class="nav flex-column" id="inbox-menu">
                        <li class="nav-item">
                            <span class="badge badge-pill"></span>
                            <a class="nav-link" data-ajax='true' data-target='#inbox-tasks'
                               data-url='{{ path('workarea_get_tasks', {'taskListName': 'focus'}) }}'
                               href="#focus">Focus</a>
                        </li>
                        <li class="nav-item">
                            <span class="badge badge-pill" id="urgent-pill"></span>
                            <a class="nav-link" data-ajax='true' data-target='#inbox-tasks'
                               data-url='{{ path('workarea_get_tasks', {'taskListName': 'urgent'}) }}'
                               href="#urgent">Urgent</a>
                        </li>
                        <li class="nav-item">
                            <span class="badge badge-pill" id="completedToday-pill">{{ completedTodayCount }}</span>
                            <a class="nav-link" data-ajax='true' data-target='#inbox-tasks'
                               data-url='{{ path('workarea_get_tasks', {'taskListName': 'completedToday'}) }}'
                               href="#completedToday">Completed Today</a>
                        </li>
                        {% for taskList in taskLists %}
                            <li class="nav-item">
                                <span class="badge badge-pill">{{ taskList.tasks|length }}</span>
                                <a class="nav-link" data-ajax='true' data-target='#inbox-tasks'
                                   data-url='{{ path('workarea_get_tasks', {'taskListName': taskList.name}) }}'
                                   href="#{{ taskList.name }}">{{ taskList.name }}</a>
                            </li>
                        {% endfor %}
                    </ul>
                </div><!-- .col-wrapper -->
            </div><!-- .col-2 -->
            <div class="col-xs-12 col-sm-6 col-md-8 col-lg-8">
                <div class="col-wrapper" id='inbox-tasks'>
                    <div id="focus"></div>
                    <div id="urgent"></div>
                    <div id="completedToday"></div>
{#                    {{ tasks_view.ul(focus, {displayListName: 'workarea'}) }}#}
                </div>
            </div><!-- .col-8 -->
            <div class="col-xs-12 col-sm-6 col-md-2 col-lg-2">
                <div class="col-wrapper" id='inbox-days'>
                    {% if days|length %}
                        {# {% include 'AppBundle:days:days_list.html.twig' %} #}
                        {% include 'AppBundle:days:_list_summary.html.twig' %}
                    {% endif %}
                    <!-- END OF ACCOUNTS -->
                    {% if accounts|length %}
                        {% set hideEmpty = true %}
                        {% for key, progress in earned %}
                            {% if 'monthly' == key %}
                                {% include 'dashboard/progressBars.html.twig' with {'total': attribute(costOfLife, key), 'progress': progress, 'issued': issuedThisMonth} %}
                            {% else %}
                                {% include 'dashboard/progressBars.html.twig' with {'total': attribute(costOfLife, key), 'progress': progress} %}
                            {% endif %}
                        {% endfor %}
                        {% include 'AppBundle:accounts:accounts_list_summary.html.twig' %}
                    {% endif %}
                    <!-- END OF ACCOUNTS -->
                </div><!-- .col-wrapper -->
            </div><!-- .col-2 -->
        </div><!-- .row -->
    </div><!-- #inbox -->
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script> Tasks.bindInbox();</script>
{% endblock %}
