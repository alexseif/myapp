{% extends 'base.html.twig' %}
{% import "macros/a.html.twig" as a %}
{% import "macros/badges.html.twig" as badge %}

{% block floatingActions %}{{ a.add('item_new') }}{% endblock %}

{% block title %}Items{% endblock %}
{% block content %}
{# TODO: [ITEM]  macro #}
  <div class="container">
    <h1>Items</h1>
    <div class="table-responsive">
      <table class="table table-striped table-hover table-dark">
        <thead>
          <tr>
            <th>Title</th>
            <th>Priority</th>
            <th>Sort</th>
            <th>Type</th>
            <th>CreatedAt</th>
            <th>actions</th>
          </tr>
        </thead>
        <tbody>
          {% for item in items %}
            <tr>
              <td>{{ item.title }}</td>
              <td>{{ item.priority }}</td>
              <td>{{ item.sort }}</td>
              <td>{{ item.type }}</td>
              <td>{{ item.createdAt ? item.createdAt|date('Y-m-d H:i:s') : '' }}</td>
              <td>
                {{ a.show('item_show', { 'id': item.id }) }}
                {{ a.edit('item_edit', { 'id': item.id }) }}
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="9">no records found</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div><!-- .table-responsive -->
  </div><!-- .container -->
{% endblock %}
